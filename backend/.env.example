# ─── Auto-Dunning Scheduler ───────────────────────────────────────
# How often to scan overdue invoices (in minutes).
# Cooldown rules prevent duplicate emails — safe to run frequently.
# 60 = every hour | 30 = every 30 min | 1440 = once a day
AUTO_DUNNING_INTERVAL_MINUTES=60

